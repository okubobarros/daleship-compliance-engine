NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.<project-ref>.supabase.co:5432/postgres
VOYAGE_API_KEY=

# Tuning de rate limit da Voyage (opcional). Defaults são conservadores p/ FREE TIER
# (~10K tokens/min). Com billing habilitado (paid: ~2000 RPM / 3M TPM), destrave a
# velocidade — a mesma carga cai de horas para segundos, dentro dos 50M tokens grátis:
#   VOYAGE_TPM=2000000
#   VOYAGE_TOKEN_BUDGET_LOTE=100000

# Google Gemini — extração de documentos (Nó 1). gemini-2.5-flash / gemini-3.5-flash rodam no
# free tier; gemini-2.5-pro exige billing. Chave em https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
